{
  "name": "@template/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --port $(bun -e \"console.log(require('../../app.config.json').services.mobile.port)\")",
    "start": "expo start --port $(bun -e \"console.log(require('../../app.config.json').services.mobile.port)\")",
    "android": "expo start --android --port $(bun -e \"console.log(require('../../app.config.json').services.mobile.port)\")",
    "ios": "expo start --ios --port $(bun -e \"console.log(require('../../app.config.json').services.mobile.port)\")",
    "web": "expo start --web --port $(bun -e \"console.log(require('../../app.config.json').services.mobile.port)\")",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@softnetics/hono-react-query": "^1.3.1",
    "@tanstack/react-query": "^5.96.1",
    "@template/web": "workspace:*",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "hono": "^4.12.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
