{
  "name": "sandbox-app-template",
  "description": "Full-stack app template with website, desktop, mobile, and API",
  "services": {
    "website": {
      "name": "Website",
      "type": "website",
      "port": 3000,
      "dev": "bun run dev"
    },
    "desktop": {
      "name": "Desktop App",
      "type": "desktop",
      "port": 5174,
      "dev": "bun run dev:desktop"
    },
    "mobile": {
      "name": "Mobile App",
      "type": "mobile",
      "port": 8081,
      "dev": "bun run dev:mobile"
    }
  }
}
