{
  "name": "sandbox-app-template",
  "description": "Full-stack app template with web, desktop, mobile, and API",
  "services": {
    "api": {
      "name": "API Server",
      "type": "api",
      "port": 3000,
      "dev": "bun run dev:api"
    },
    "web": {
      "name": "Web App",
      "type": "web",
      "port": 5173,
      "dev": "bun run dev:web"
    },
    "desktop": {
      "name": "Desktop App",
      "type": "desktop",
      "port": 5174,
      "dev": "bun run dev:desktop"
    },
    "mobile": {
      "name": "Mobile App",
      "type": "mobile",
      "port": 8081,
      "dev": "bun run dev:mobile"
    }
  }
}
